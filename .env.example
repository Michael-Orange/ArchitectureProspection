# ================================
  # DUST AI CONFIGURATION (REQUIRED)
  # ================================
  # Get these from your Dust workspace at https://dust.tt/
  # Settings > Workspace > API Keys
  DUST_API_KEY=sk-dust-your-api-key-here
  DUST_WORKSPACE_ID=w-your-workspace-id-here
  DUST_AGENT_ID=dust  # Optional: specific agent to use for qualification

  # ================================
  # CRON SCHEDULE (OPTIONAL)
  # ================================
  # Default: "0 15 * * 6" (Every Saturday at 3:00 PM UTC)
  # Examples:
  #   - "0 9 * * 1" : Every Monday at 9:00 AM UTC
  #   - "0 15 1,15 * *" : 1st and 15th of each month at 3:00 PM UTC
  #   - "0 14 * * 3" : Every Wednesday at 2:00 PM UTC
  SCHEDULE_CRON_EXPRESSION=0 15 * * 6

  # ================================
  # GOOGLE PLACES API (OPTIONAL)
  # ================================
  # Improves discovery results - get from https://console.cloud.google.com/
  GOOGLE_PLACES_API_KEY=your-google-api-key-here

  # ================================
  # DATABASE (AUTO-CONFIGURED)
  # ================================
  # This is automatically provided by Replit
  # DATABASE_URL=postgresql://...

  # ================================
  # EMAIL CONFIGURATION (OPTIONAL)
  # ================================
  # Recipient email is hardcoded to michael@filtreplante.com
  # But you can override if needed for testing
  # EMAIL_RECIPIENT=your-email@example.com

  # ================================
  # DUST AI SCORING
  # ================================
  # Score range: 1-5 (not 0-10)
  # - Score 1-2: Not qualified
  # - Score 3-5: Qualified (exported to CSV)
  # Minimum qualification score: 3
  